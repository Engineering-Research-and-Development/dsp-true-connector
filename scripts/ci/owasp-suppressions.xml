<?xml version="1.0" encoding="UTF-8"?>
<!--
  OWASP Dependency-Check — suppression file
  ==========================================
  Add entries here to suppress false-positive CVE findings after manual triage.

  Format reference:
    https://jeremylong.github.io/DependencyCheck/general/suppressing.html

  Each <suppress> element needs:
    <notes>        — WHY this is suppressed (mandatory for audit trail)
    <packageUrl>   — pkg:maven/<groupId>/<artifactId>@<version>  (supports regex)
    <cve>          — the specific CVE identifier, e.g. CVE-2024-12345
                     OR <cvssBelow> to suppress by score

  ─── How to populate this file ────────────────────────────────────────────
  1. Run:  mvn verify -Powasp -Dowasp.failBuildOnCVSS=11
     (CVSS=11 means report-only; the build will not fail)
  2. Open:  <module>/target/dependency-check/dependency-check-report.html
  3. For each finding decide:
       - True positive → upgrade the dependency
       - False positive → add a <suppress> entry here with a justification note
  ──────────────────────────────────────────────────────────────────────────
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
    ═══════════════════════════════════════════════════════════════════════════
    TEMPLATE — copy and fill in when you triage a false positive:

    <suppress>
        <notes><![CDATA[
            CVE-XXXX-XXXXX: False positive — the vulnerable code path in
            <library> is not reachable because <reason>.
            Reviewed by: <name>, <date>.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/com\.example/some\-artifact@.*$</packageUrl>
        <cve>CVE-XXXX-XXXXX</cve>
    </suppress>
    ═══════════════════════════════════════════════════════════════════════════
    -->

</suppressions>

